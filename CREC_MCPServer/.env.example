# CREC MCPServer 環境設定サンプル
# このファイルを ".env" にコピーしてから値を編集してください。

# LLM バックエンドの URL（Ollama / LM Studio 等 OpenAI 互換 API）
LLM_URL=http://localhost:11434

# 使用するモデル名（Ollama の場合は pull 済みのモデル名を指定）
LLM_MODEL=llama3.2

# MCP サーバのバインドアドレス（通常は変更不要）
MCP_HOST=127.0.0.1

# MCP サーバのポート番号（CREC Web の appsettings.json の McpServer:Url と合わせること）
MCP_PORT=8765

# LLM リクエストのタイムアウト（秒）
LLM_TIMEOUT=120

# システムプロンプトに注入するページコンテキストの最大文字数
# モデルのコンテキストウィンドウが小さい場合はこの値を下げてください
# （n_keep >= n_ctx の 400 エラーが発生する場合は 800 程度に下げると効果的）
MAX_CONTEXT_CHARS=1200

# LLM に送信する会話履歴の最大ターン数（user+assistant のペア数）
# コンテキストウィンドウに収まらない場合は古いターンから削除されます
MAX_HISTORY_TURNS=8

# 以下はオプション。未設定の場合はデフォルトのホワイトリストが適用されます。
# ボタン ID のホワイトリスト（カンマ区切り）
# SAFE_BUTTON_IDS=addNewCollectionBtn,editProjectBtn,...

# フォームフィールド ID のホワイトリスト（カンマ区切り）
# SAFE_INPUT_IDS=operationType,operationQuantity,...
