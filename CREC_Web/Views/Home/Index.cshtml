                    panelEventHandlers.set(panel, {
                        prevBtn: prevBtn,
                        nextBtn: nextBtn,
                        prevHandler: prevHandler,
                        nextHandler: nextHandler
                    });
                }, ANIMATION_DELAY);
            }
